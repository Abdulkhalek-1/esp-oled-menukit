---
Checks: >
  -*,
  bugprone-*,
  cert-*,
  -cert-err58-cpp,
  -cert-dcl21-cpp,
  readability-*,
  -readability-braces-around-statements,
  -readability-magic-numbers,
  -readability-identifier-length,
  performance-*,
  clang-analyzer-*

WarningsAsErrors: ''
HeaderFilterRegex: '(components|main)/.*\.h$'
FormatStyle: file
